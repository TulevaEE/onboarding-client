{
  "hooks": {
    "postToolUse": [
      {
        "matcher": "write|edit|notebookedit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_FILE_PATHS"
          },
          {
            "type": "command",
            "command": "npx eslint $CLAUDE_FILE_PATHS"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit"
          }
        ]
      }
    ]
  }
}